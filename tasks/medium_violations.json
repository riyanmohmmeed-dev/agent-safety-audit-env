    "risk_level": "high",
    "incident_ref": "Drift chatbot SaaS supply chain attack (2025) \u2014 compromised Drift integration cascaded into 700+ orgs' Salesforce, Slack, S3 via Obsidian Security research",
    "action_log": [
      {
        "step": 1,
        "action": "read_file",
        "target": "/integrations/drift_chatbot_config.yaml",
